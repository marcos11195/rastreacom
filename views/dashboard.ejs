<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <title>Inspector - Rastreacom</title>
        <link rel="stylesheet" href="/css/style.css">
    </head>
    <body>

        <div class="header">
            <div style="display:flex; align-items:center; gap:15px;">
                <h2 style="margin:0;">🔎 Inspector</h2>
                <form id="searchForm" action="/auth/buscar" method="POST"
                    style="display:flex; gap:8px;">
                    <input type="text" name="query" placeholder="Ej: Puig Samba"
                        required>
                    <button type="submit" class="btn-search">Buscar</button>
                </form>

                <div id="loadingStatus"
                    style="display:none; align-items:center; gap:8px; margin-left:10px; color:#0e639c; font-weight:bold; font-size:0.9em;">
                    <div class="spinner"></div> Sincronizando datos en vivo...
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:15px;">
                <span>Hola, <strong><%= currentUser.nombre %></strong></span>
                <form action="/auth/borrar" method="POST">
                    <button type="submit" class="btn-clear">Vaciar DB</button>
                </form>
                <a href="/auth/logout"
                    style="color:red; text-decoration:none; font-size:0.8em;">Salir</a>
            </div>
        </div>

        <div class="wrapper">
            <div class="sidebar">
                <div class="user-info">
                    Conectado: <%= currentUser.email %>
                </div>
                <div class="tabs">
                    <button class="tab-btn active"
                        onclick="cambiarTienda('Zalando')">Zalando</button>
                    <button class="tab-btn"
                        onclick="cambiarTienda('Adidas')">Adidas</button>
                </div>
                <div id="product-list"></div>
                <div class="pagination" id="pagination"></div>
            </div>

            <div class="content">
                <div class="inspector-header">
                    <h4 id="ins-titulo"
                        style="margin:0 0 10px 0; color:white;">Selecciona un
                        producto</h4>
                    <input type="text" id="ins-filter" class="filter-box"
                        placeholder="Filtrar en JSON..."
                        onkeyup="filtrarJson()">
                </div>
                <pre
                    id="jsonViewer">// Selecciona un item para inspeccionar el JSON</pre>
            </div>
        </div>

        <script>
            window.todosLosProductos = <%- JSON.stringify(productos) %>;
            let refreshInterval = null;
            let stableTicks = 0; 

            document.getElementById('searchForm').onsubmit = async function(e) {
                e.preventDefault();
                
                document.getElementById('loadingStatus').style.display = 'flex';
                const btn = this.querySelector('.btn-search');
                btn.disabled = true;

                const formData = new FormData(this);
                const query = new URLSearchParams(formData).toString();

                fetch('/auth/buscar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: query
                });

                if (refreshInterval) clearInterval(refreshInterval);
                stableTicks = 0;
                
                refreshInterval = setInterval(async () => {
                    try {
                        const res = await fetch('/auth/api/productos?t=' + Date.now());
                        const nuevosDatos = await res.json();
                        
                        // Generamos el hash sobre los datos críticos: ID, Precio y Fecha de actualización
                        const hashNuevo = nuevosDatos.map(p => p._id + p.precio + p.ultimaActualizacion).join('|');
                        const hashViejo = window.todosLosProductos.map(p => p._id + p.precio + p.ultimaActualizacion).join('|');

                        if (hashNuevo !== hashViejo) {
                            console.log("Sincronizando cambios...");
                            window.todosLosProductos = nuevosDatos;
                            stableTicks = 0; 
                            if (typeof renderizar === 'function') renderizar();
                        } else {
                            const hayPendientes = nuevosDatos.some(p => p.precio === 'Pendiente...');
                            if (!hayPendientes) stableTicks++;
                        }

                        if (stableTicks >= 15) { 
                            detenerPolling(btn);
                        }
                    } catch (err) {
                        console.error("Error en Live Search:", err);
                    }
                }, 2000);
            };

            function detenerPolling(btn) {
                if (refreshInterval) {
                    clearInterval(refreshInterval);
                    refreshInterval = null;
                }
                document.getElementById('loadingStatus').style.display = 'none';
                btn.disabled = false;
                console.log("Polling finalizado.");
            }
        </script>
        <script src="/js/inspector.js"></script>
    </body>
</html>